  langid = {english},
  file = {C:\Users\kozac\Zotero\storage\7G4NSW68\Bak et al. - 2023 - A Systematic Literature Review of Supply Chain Resilience in Small–Medium Enterprises (SMEs) A Call.pdf}
}

