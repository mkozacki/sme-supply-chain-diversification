  shorttitle = {A {{Systematic Literature Review}} of {{Supply Chain Resilience}} in {{Small}}--{{Medium Enterprises}} ({{SMEs}})},
  author = {Bak, Ozlem and Shaw, Sarah and Colicchia, Claudia and Kumar, Vikas},
  year = 2023,
  month = jan,
  journal = {IEEE Transactions on Engineering Management},
  volume = {70},
